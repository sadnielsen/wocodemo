<Window x:Class="WoCo.Wpf.Views.AddRevisionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add New Revision" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="300" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Configuration -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Project Name -->
            <StackPanel Grid.Row="0" Margin="0,5">
                <TextBlock Text="Project:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <TextBlock x:Name="ProjectNameTextBlock" 
                           Text="[Project Name]" 
                           FontSize="14" 
                           Margin="10,0,0,0" />
            </StackPanel>

            <!-- Revision Number -->
            <StackPanel Grid.Row="1" Margin="0,10,0,5">
                <TextBlock Text="Revision Number:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <TextBlock x:Name="RevisionNumberTextBlock" 
                           Text="[Next Revision Number]" 
                           FontSize="14" 
                           Margin="10,0,0,0" />
            </StackPanel>

            <!-- File Selection -->
            <StackPanel Grid.Row="2" Margin="0,10,0,5">
                <TextBlock Text="Select Floorplan File:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathTextBox" 
                             Grid.Column="0"
                             IsReadOnly="True" 
                             Margin="0,0,5,0"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="BrowseButton" 
                            Grid.Column="1"
                            Content="Browse..." 
                            Width="80"
                            Click="BrowseButton_Click" />
                </Grid>
            </StackPanel>

            <!-- File Info -->
            <StackPanel Grid.Row="3" Margin="0,10,0,5">
                <TextBlock x:Name="FileInfoTextBlock" 
                           Text="" 
                           FontStyle="Italic" 
                           Foreground="Gray"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Transformation Parameters -->
            <Border Grid.Row="4"
                    x:Name="TransformationPanel"
                    BorderBrush="LightGray" 
                    BorderThickness="1" 
                    Padding="10"
                    Margin="0,10,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Transformation Parameters:" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,10" />

                    <TextBlock Text="Offset coordinates (in pixels):" 
                               Foreground="Gray"
                               FontSize="11"
                               Margin="0,0,0,5" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="Offset X:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,5" />
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 x:Name="OffsetXTextBox"
                                 Text="0"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,5" />

                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="Offset Y:" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 x:Name="OffsetYTextBox"
                                 Text="0"
                                 VerticalContentAlignment="Center" />
                    </Grid>

                    <TextBlock Text="Click on the preview to set the offset point."
                               FontSize="10"
                               FontStyle="Italic"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">
                <Button x:Name="OkButton" 
                        Content="OK" 
                        Width="80" 
                        Height="30"
                        IsEnabled="False"
                        Margin="0,0,10,0"
                        Click="OkButton_Click" />
                <Button x:Name="CancelButton" 
                        Content="Cancel" 
                        Width="80" 
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="LightGray" />

        <!-- Right Panel: Preview -->
        <Border Grid.Column="2" 
                BorderBrush="LightGray" 
                BorderThickness="1"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Preview Header -->
                <Border Grid.Row="0" 
                        Background="#F5F5F5" 
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Floorplan Preview" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" />
                        <TextBlock x:Name="PreviewInfoTextBlock"
                                   Text="Click on the image to set the offset point."
                                   FontSize="11"
                                   Foreground="Gray"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <!-- Preview Area -->
                <ScrollViewer Grid.Row="1" 
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#FAFAFA">
                    <Grid x:Name="PreviewContainer">
                        <!-- Placeholder -->
                        <TextBlock x:Name="PreviewPlaceholder"
                                   Text="Select a floorplan file to see preview..."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   FontStyle="Italic" />

                        <!-- Floorplan Image -->
                        <Canvas x:Name="PreviewCanvas">
                            <Image x:Name="PreviewImage"
                                   Stretch="None"
                                   MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                                   Cursor="Cross" />

                            <!-- Offset Point Marker -->
                            <Ellipse x:Name="OffsetMarker"
                                     Width="12"
                                     Height="12"
                                     Fill="Red"
                                     Stroke="White"
                                     StrokeThickness="2"
                                     Visibility="Collapsed" />

                            <!-- Crosshair Lines -->
                            <Line x:Name="CrosshairH"
                                  Stroke="Red"
                                  StrokeThickness="1"
                                  StrokeDashArray="4,2"
                                  Visibility="Collapsed" />
                            <Line x:Name="CrosshairV"
                                  Stroke="Red"
                                  StrokeThickness="1"
                                  StrokeDashArray="4,2"
                                  Visibility="Collapsed" />
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
