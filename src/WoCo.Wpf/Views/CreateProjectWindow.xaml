<Window x:Class="WoCo.Wpf.Views.CreateProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create New Project" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="300" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Configuration -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Project Name -->
            <StackPanel Grid.Row="0" Margin="0,5">
                <TextBlock Text="Project Name:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <TextBox x:Name="ProjectNameTextBox" 
                         VerticalContentAlignment="Center" 
                         Margin="0,0,0,0"
                         TextChanged="ProjectNameTextBox_TextChanged" />
            </StackPanel>

            <!-- Floorplan File Selection -->
            <StackPanel Grid.Row="1" Margin="0,10,0,5">
                <TextBlock Text="Select Floorplan File:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FloorplanFilePathTextBox" 
                             Grid.Column="0"
                             IsReadOnly="True" 
                             Margin="0,0,5,0"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="BrowseFloorplanButton" 
                            Grid.Column="1"
                            Content="Browse..." 
                            Width="80"
                            Click="BrowseFloorplanButton_Click" />
                </Grid>
            </StackPanel>

            <!-- Annotations File Selection -->
            <StackPanel Grid.Row="2" Margin="0,10,0,5">
                <TextBlock Text="Select Annotations File:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AnnotationsFilePathTextBox" 
                             Grid.Column="0"
                             IsReadOnly="True" 
                             Margin="0,0,5,0"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="BrowseAnnotationsButton" 
                            Grid.Column="1"
                            Content="Browse..." 
                            Width="80"
                            Click="BrowseAnnotationsButton_Click" />
                </Grid>
            </StackPanel>

            <!-- File Info -->
            <StackPanel Grid.Row="3" Margin="0,10,0,5">
                <TextBlock x:Name="FileInfoTextBlock" 
                           Text="" 
                           FontStyle="Italic" 
                           Foreground="Gray"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Scale Denominator -->
            <StackPanel Grid.Row="4" Margin="0,10,0,5">
                <TextBlock Text="Scale Denominator:" FontWeight="SemiBold" Margin="0,0,0,5" />
                <TextBox x:Name="ScaleDenominatorTextBox" 
                         Text="1.0"
                         VerticalContentAlignment="Center" />
                <TextBlock Text="Enter the scale denominator for the floorplan (e.g., 100 for 1:100 scale)."
                           FontSize="10"
                           FontStyle="Italic"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">
                <Button x:Name="OkButton" 
                        Content="OK" 
                        Width="80" 
                        Height="30"
                        IsEnabled="False"
                        Margin="0,0,10,0"
                        Click="OkButton_Click" />
                <Button x:Name="CancelButton" 
                        Content="Cancel" 
                        Width="80" 
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="LightGray" />

        <!-- Right Panel: Preview -->
        <Border Grid.Column="2" 
                BorderBrush="LightGray" 
                BorderThickness="1"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Preview Header -->
                <Border Grid.Row="0" 
                        Background="#F5F5F5" 
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Floorplan Preview" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" />
                        <TextBlock x:Name="PreviewInfoTextBlock"
                                   Text="Select a floorplan file to see preview."
                                   FontSize="11"
                                   Foreground="Gray"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <!-- Preview Area -->
                <ScrollViewer Grid.Row="1" 
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#FAFAFA">
                    <Grid x:Name="PreviewContainer">
                        <!-- Placeholder -->
                        <TextBlock x:Name="PreviewPlaceholder"
                                   Text="Select a floorplan file to see preview..."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   FontStyle="Italic" />

                        <!-- Floorplan Image -->
                        <Canvas x:Name="PreviewCanvas">
                            <Image x:Name="PreviewImage"
                                   Stretch="None" />
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
