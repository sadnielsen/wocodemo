<UserControl x:Class="WoCo.Wpf.Controls.FloorplanViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WoCo.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <GroupBox Header="Floorplan" Margin="5">
        <DockPanel>
            <!-- Toolbar -->
            <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
                <ToolBar>
                    <Button x:Name="ZoomInButton" Content="🔍+" ToolTip="Zoom In" Padding="5,2" />
                    <Button x:Name="ZoomOutButton" Content="🔍-" ToolTip="Zoom Out" Padding="5,2" />
                    <Button x:Name="FitButton" Content="⬜" ToolTip="Fit to Window" Padding="5,2" />
                    <Separator />
                    <Button x:Name="PanButton" Content="✋" ToolTip="Pan Mode" Padding="5,2" />
                    <Button x:Name="AnnotateButton" Content="✏️" ToolTip="Add Annotation" Padding="5,2" />
                    <Separator />
                    <ComboBox x:Name="LayerComboBox" Width="120" ToolTip="Layer Selection">
                        <ComboBoxItem Content="All Layers" IsSelected="True" />
                        <ComboBoxItem Content="Floorplan" />
                        <ComboBoxItem Content="Annotations" />
                        <ComboBoxItem Content="Measurements" />
                    </ComboBox>
                    <Separator />
                    <TextBlock Text="Zoom: " VerticalAlignment="Center" Margin="5,0" />
                    <TextBlock x:Name="ZoomLevelText" Text="100%" VerticalAlignment="Center" MinWidth="40" />
                </ToolBar>
            </ToolBarTray>

            <!-- Floorplan Display Area -->
            <Border BorderBrush="DarkGray" BorderThickness="1">
                <Grid>
                    <ScrollViewer x:Name="FloorplanScrollViewer" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Viewbox x:Name="FloorplanViewbox" Stretch="Uniform">
                                <Canvas x:Name="FloorplanCanvas" 
                                        Background="WhiteSmoke"
                                        Width="800" 
                                        Height="600">
                                    <!-- Floorplan Image -->
                                    <Image x:Name="FloorplanImage" 
                                           Stretch="Uniform" />
                                    
                                    <!-- Annotations Layer -->
                                    <Canvas x:Name="AnnotationsCanvas" 
                                            Width="800" 
                                            Height="600" 
                                            Background="Transparent" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </ScrollViewer>
                    
                    <!-- Placeholder when no floorplan is loaded -->
                    <TextBlock x:Name="PlaceholderText"
                               Text="Select a project and revision to view floorplan"
                               FontSize="16"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DockPanel>
    </GroupBox>
</UserControl>
