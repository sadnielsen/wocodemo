<UserControl x:Class="WoCo.Wpf.Controls.ProjectTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WoCo.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="250">
    <GroupBox Header="Projects &amp; Revisions" Margin="5">
        <TreeView x:Name="ProjectsTreeView">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Revisions}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁 " />
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                    </StackPanel>
                    <HierarchicalDataTemplate.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄 " />
                                <TextBlock Text="Rev " />
                                <TextBlock Text="{Binding Version}" FontWeight="SemiBold" />
                                <TextBlock Text=" - " />
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" 
                                           Foreground="Gray" />
                            </StackPanel>
                        </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </GroupBox>
</UserControl>
