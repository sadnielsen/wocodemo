<UserControl x:Class="WoCo.Wpf.Controls.MetaInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WoCo.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="250">
    <GroupBox Header="Details" Margin="5">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="5">
                <!-- Project Name -->
                <TextBlock Text="Project:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding ProjectName, TargetNullValue='(No selection)'}" 
                           Margin="0,0,0,10" />
                
                <!-- Revision -->
                <TextBlock Text="Revision:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Revision, TargetNullValue='-'}" 
                           Margin="0,0,0,10" />
                
                <!-- Date -->
                <TextBlock Text="Date:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}', TargetNullValue='-'}" 
                           Margin="0,0,0,10" />
                
                <!-- Description -->
                <TextBlock Text="Description:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Description, TargetNullValue='-'}" 
                           TextWrapping="Wrap" 
                           Margin="0,0,0,10" />
                
                <!-- Status -->
                <TextBlock Text="Status:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Status, TargetNullValue='-'}" 
                           Margin="0,0,0,10" />
                
                <!-- Created By -->
                <TextBlock Text="Created By:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding CreatedBy, TargetNullValue='-'}" 
                           Margin="0,0,0,10" />
                
                <!-- Notes -->
                <TextBlock Text="Notes:" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Text="{Binding Notes, TargetNullValue='-'}" 
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </GroupBox>
</UserControl>
