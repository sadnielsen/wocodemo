<Window x:Class="FloorplanAnnotator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FloorplanAnnotator.Views"
        mc:Ignorable="d"
        Title="Floorplan Annotator"
        Height="700"
        Width="1100"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Toolbar -->
            <RowDefinition Height="*" />
            <!-- Content -->
            <RowDefinition Height="Auto" />
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="#F5F5F5">
            <Button Command="{Binding NewProjectCommand}"
                    Padding="10,4"
                    ToolTip="Create a new project">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2795;" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="New Project" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Separator />
            <Button Command="{Binding DeleteProjectCommand}"
                    Padding="10,4"
                    ToolTip="Delete selected project">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F5D1;" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="Delete" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Main Content: Project List + Canvas -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Project List -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top"
                        Background="#EBEBEB"
                        BorderBrush="#CCCCCC"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="Projects"
                               FontWeight="Bold"
                               FontSize="13"
                               Padding="8,6" />
                </Border>

                <ListBox ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding CreatedAt, StringFormat='Created: {0:yyyy-MM-dd HH:mm}'}"
                                           FontSize="10"
                                           Foreground="#888888" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="#DDDDDD"
                          ShowsPreview="True" />

            <!-- Right Panel: Canvas + Annotation List -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="160" MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- Empty state message -->
                <TextBlock Grid.Row="0"
                           Text="Select or create a project to view the floorplan."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#888888"
                           FontSize="14"
                           Visibility="{Binding HasSelectedProject,
                               Converter={StaticResource BoolToVisConverter},
                               ConverterParameter=Invert}" />

                <!-- Floorplan Canvas -->
                <views:AnnotationCanvas
                    Grid.Row="0"
                    FloorplanPath="{Binding SelectedProject.FloorplanPath}"
                    Annotations="{Binding SelectedProjectAnnotations}"
                    Visibility="{Binding HasSelectedProject,
                        Converter={StaticResource BoolToVisConverter}}" />

                <!-- Splitter -->
                <GridSplitter Grid.Row="1"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              Background="#DDDDDD"
                              ShowsPreview="True" />

                <!-- Annotations Table -->
                <DockPanel Grid.Row="2">
                    <Border DockPanel.Dock="Top"
                            Background="#EBEBEB"
                            BorderBrush="#CCCCCC"
                            BorderThickness="0,1,0,1"
                            Visibility="{Binding HasSelectedProject,
                                Converter={StaticResource BoolToVisConverter}}">
                        <TextBlock Text="Annotations"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Padding="8,4" />
                    </Border>

                    <DataGrid ItemsSource="{Binding SelectedProjectAnnotations}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              Visibility="{Binding HasSelectedProject,
                                  Converter={StaticResource BoolToVisConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90" />
                            <DataGridTextColumn Header="Coordinates" Binding="{Binding Coordinates}" Width="*" />
                            <DataGridTemplateColumn Header="Color" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Color}"
                                                Width="20" Height="14"
                                                CornerRadius="2"
                                                HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#EBEBEB">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="80" Height="12"
                                 IsIndeterminate="True"
                                 Margin="0,0,8,0"
                                 Visibility="{Binding IsLoading,
                                     Converter={StaticResource BoolToVisConverter}}" />
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
